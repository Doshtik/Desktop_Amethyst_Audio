<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- COLORS -->
    <Color x:Key="SurfaceBaseColor">#1E1F22</Color>
    <Color x:Key="SurfaceContainerColor">#2A2C2F</Color>
    <Color x:Key="OutlineSubtleColor">#3A3C3F</Color>
    <Color x:Key="ContentPrimaryColor">#E6E6E6</Color>
    <Color x:Key="ContentMutedColor">#8E9297</Color>
    <Color x:Key="AccentMainColor">#8A2BE2</Color>
    <Color x:Key="AccentHoverColor">#9B4DFF</Color>
    <Color x:Key="ColorStatusError">#C32A2A</Color>
    <Color x:Key="ColorStatusErrorContainer">#441A1A</Color>
    
    <!-- BACKGROUNDS -->
    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainerColor}" />

    <!-- BORDERS -->
    <SolidColorBrush x:Key="OutlineSubtleBrush" Color="{StaticResource OutlineSubtleColor}" />

    <!-- CONTENT -->
    <SolidColorBrush x:Key="ContentPrimaryBrush" Color="{StaticResource ContentPrimaryColor}" />
    <SolidColorBrush x:Key="ContentMutedBrush" Color="{StaticResource ContentMutedColor}" />

    <!-- ACCENTS -->
    <SolidColorBrush x:Key="AccentMainBrush" Color="{StaticResource AccentMainColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    
    <!-- ERRORS -->
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource ColorStatusError}" />
    <SolidColorBrush x:Key="StatusErrorContainerBrush" Color="{StaticResource ColorStatusErrorContainer}" />
</ResourceDictionary>