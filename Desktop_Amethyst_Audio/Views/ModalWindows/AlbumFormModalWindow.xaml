<Window x:Class="Desktop_Amethyst_Audio.Views.ModalWindows.AlbumFormModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.ModalWindows"
        mc:Ignorable="d" Loaded="AlbumFormModalWindow_OnLoaded" FontSize="14"
        Title="AlbumFormModalWindow" Height="425" Width="600">
    <Grid Background="{DynamicResource SurfaceBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="10 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="CoverImage" Grid.Column="0" Source="../../Assets/default-track-cover.png" 
                   Width="150" Margin="0 10 10 10"/>
            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0 0 0 5">
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Выберите обложку" Grid.Row="0"
                               Foreground="{DynamicResource ContentPrimaryBrush}"
                               VerticalAlignment="Bottom"/>
                    <Button x:Name="ChooseCoverFileButton" Grid.Row="1"  Margin="0 5 0 0"
                            Background="{DynamicResource SurfaceContainerBrush}"
                            Foreground="{DynamicResource ContentMutedBrush}"
                            BorderBrush="{DynamicResource OutlineSubtleBrush}"
                            BorderThickness="2"
                            Padding="10 5"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Content="Выбрать"
                            Click="ChooseCoverFileButton_OnClick"/>
                </Grid>
            </Grid>
        </Grid>
        <StackPanel Orientation="Vertical" Grid.Row="1" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="Название" Grid.Row="0"
                           Margin="0 5"
                           Foreground="{DynamicResource ContentPrimaryBrush}"/>
                <TextBox x:Name="NameTextBox" Grid.Row="1" 
                         Padding="5"
                         VerticalAlignment="Top"
                         Background="{DynamicResource SurfaceContainerBrush}"
                         Foreground="{DynamicResource ContentPrimaryBrush}"
                         BorderBrush="{DynamicResource OutlineSubtleBrush}"
                         BorderThickness="2"/>
            </Grid>
            <Grid Margin="0 10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="Выбрать треки" Foreground="{DynamicResource ContentPrimaryBrush}"
                           Margin="0 5"
                           Grid.Row="0"/>
                <Button x:Name="SelectTrackButton"
                        Content="Выбрать"
                        Padding="5"
                        Click="SelectTrackButton_OnClick"
                        Background="{DynamicResource SurfaceContainerBrush}"
                        Foreground="{DynamicResource ContentPrimaryBrush}"
                        BorderBrush="{DynamicResource OutlineSubtleBrush}"
                        BorderThickness="2"
                        Grid.Row="1" />
            </Grid>
        </StackPanel>
        <Button x:Name="ConfirmButton" Grid.Row="2" Margin="10"  Padding="20"
                Content="Подтвердить"
                Click="ConfirmButton_OnClick"
                Foreground="{DynamicResource ContentPrimaryBrush}"
                Background="{DynamicResource SurfaceContainerBrush}"
                BorderBrush="{DynamicResource OutlineSubtleBrush}"
                BorderThickness="2"/>
        <Frame x:Name="TrackFrame" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed"/>
    </Grid>
</Window>
