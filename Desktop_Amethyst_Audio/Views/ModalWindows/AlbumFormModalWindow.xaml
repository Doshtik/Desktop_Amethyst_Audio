<Window x:Class="Desktop_Amethyst_Audio.Views.ModalWindows.AlbumFormModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.ModalWindows"
        mc:Ignorable="d" Background="Transparent"
        Loaded="AlbumFormModalWindow_OnLoaded" FontSize="14"
        Title="AlbumFormModalWindow" Height="400" Width="600">
    <Border Background="{DynamicResource SurfaceBaseBrush}" 
            BorderBrush="{DynamicResource OutlineSubtleBrush}"
            BorderThickness="2"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="10 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Image x:Name="CoverImage" Grid.Column="0" Source="../../Assets/default-track-cover.png" Width="150" Margin="0 10 10 10"/>
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0 0 0 5">
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Выберите обложку" Grid.Row="0"
                                   Foreground="{DynamicResource ContentPrimaryBrush}"
                                   VerticalAlignment="Bottom"/>
                        <Button x:Name="ChooseCoverFileButton" Grid.Row="1"  Margin="0 5 0 0"
                                Background="{DynamicResource SurfaceContainerBrush}"
                                Foreground="{DynamicResource ContentMutedBrush}"
                                BorderBrush="{DynamicResource OutlineSubtleBrush}"
                                BorderThickness="2"
                                Padding="10 5"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Content="Выбрать"
                                Click="ChooseCoverFileButton_OnClick"/>
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Треки" Grid.Row="0"
                               Foreground="{DynamicResource ContentPrimaryBrush}" />
                    <ListBox x:Name="TrackListBox" Grid.Row="1" SelectionMode="Multiple" 
                             Background="Transparent"
                             BorderThickness="0" />
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Название" Grid.Row="0"
                               Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <TextBox x:Name="NameTextBox" Grid.Row="1" 
                             Padding="5"
                             VerticalAlignment="Top"
                             Background="{DynamicResource SurfaceContainerBrush}"
                             Foreground="{DynamicResource ContentPrimaryBrush}"
                             BorderBrush="{DynamicResource OutlineSubtleBrush}"
                             BorderThickness="2"/>
                </Grid>
            </Grid>
            <Grid Grid.Row="2"/>
            <Button x:Name="ConfirmButton" Grid.Row="3" Margin="10"  Padding="30"
                    Content="Подтвердить"
                    Click="ConfirmButton_OnClick"
                    Foreground="{DynamicResource ContentPrimaryBrush}"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineSubtleBrush}"
                    BorderThickness="2"/>
        </Grid>
    </Border>
</Window>
