<Window x:Class="Desktop_Amethyst_Audio.Views.ModalWindows.PlaylistSelectorModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.ModalWindows"
        mc:Ignorable="d" Loaded="PlaylistSelectorModalWindow_OnLoaded"
        FontSize="18" Background="{DynamicResource SurfaceBaseBrush}"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Title="PlaylistSelectorModalWindow" Height="600" Width="800">
    <Grid Width="600" Height="500">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="PlaylistListBox" Grid.Row="0" 
                 SelectionMode="Multiple"
                 Background="Transparent"
                 BorderBrush="{DynamicResource OutlineSubtleBrush}"
                 BorderThickness="2"/>
        <Grid Grid.Row="1" Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelButton" Grid.Column="0"
                    Content="Отмена" 
                    Click="CancelButton_OnClick"
                    Foreground="{DynamicResource ContentPrimaryBrush}"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineSubtleBrush}"
                    BorderThickness="2"
                    Padding="10" Margin="0 0 5 0"/>
            <Button x:Name="ConfirmButton" Grid.Column="1"
                    Content="Подтвердить"
                    Click="ConfirmButton_OnClick"
                    Foreground="{DynamicResource ContentPrimaryBrush}"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineSubtleBrush}"
                    BorderThickness="2"
                    Padding="10" Margin="5 0 0 0"/>
        </Grid>
    </Grid>
</Window>
