<Window x:Class="Desktop_Amethyst_Audio.Views.ModalWindows.TrackFormModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.ModalWindows"
        mc:Ignorable="d" Loaded="TrackFormModalWindow_OnLoaded"
        Background="Transparent" FontSize="14"
        Title="TrackFormModalWindow" Height="650" Width="800">
    <Border BorderThickness="2"
            BorderBrush="{DynamicResource OutlineSubtleBrush}"
            Background="{DynamicResource SurfaceBaseBrush}"
            CornerRadius="10">
        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="CoverImage" Grid.Column="0" Source="../../Assets/default-track-cover.png" Width="150" Margin="0 10 10 10"/>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" VerticalAlignment="Bottom" Margin="0 0 0 5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Выберите обложку" Grid.Row="0"
                               Foreground="{DynamicResource ContentPrimaryBrush}"
                               VerticalAlignment="Bottom"/>
                    <Button x:Name="ChooseCoverFileButton" Grid.Row="1"  Margin="0 5 0 0"
                            Background="{DynamicResource SurfaceContainerBrush}"
                            Foreground="{DynamicResource ContentMutedBrush}"
                            BorderBrush="{DynamicResource OutlineSubtleBrush}"
                            BorderThickness="2"
                            Padding="10 5"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Content="Выбрать"
                            Click="TrackCoverSelectorButton_OnClick"/>
                </Grid>
                <Grid Grid.Row="1" VerticalAlignment="Top" Margin="0 5 0 0"> 
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Выберите файл" Grid.Row="0"
                               Foreground="{DynamicResource ContentPrimaryBrush}"
                               VerticalAlignment="Bottom"/>
                    <Button x:Name="ChooseTrackFileButton" Grid.Row="1"  Margin="0 5 0 0"
                            Background="{DynamicResource SurfaceContainerBrush}"
                            Foreground="{DynamicResource ContentMutedBrush}"
                            BorderBrush="{DynamicResource OutlineSubtleBrush}"
                            BorderThickness="2"
                            Padding="10 5"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Content="Выбрать" Click="TrackFileSelectorButton_OnClick"/>
                </Grid>
            </Grid>
        </Grid>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Название" Foreground="{DynamicResource ContentPrimaryBrush}"/>
            <TextBox x:Name="NameTextBox" 
                     Background="{DynamicResource SurfaceContainerBrush}"
                     Foreground="{DynamicResource ContentMutedBrush}"
                     BorderBrush="{DynamicResource OutlineSubtleBrush}"
                     BorderThickness="2"
                     Padding="10 5"/>
            <StackPanel Margin="0 10">
                <TextBlock Text="Темп" Foreground="{DynamicResource ContentPrimaryBrush}" Margin="0 5"/>
                <ComboBox x:Name="PacesComboBox"/>
                <TextBlock Text="Настроение" Foreground="{DynamicResource ContentPrimaryBrush}" Margin="0 5"/>
                <ComboBox x:Name="MoodsComboBox"/>
                <TextBlock Text="Жанры" Foreground="{DynamicResource ContentPrimaryBrush}" Margin="0 5"/>
                <ListBox x:Name="GenreListBox" Height="50" Background="Transparent" BorderThickness="0"
                         SelectionMode="Multiple">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </StackPanel>
            <TextBlock Text="Содержит ли текст" Foreground="{DynamicResource ContentPrimaryBrush}" Margin="0 5"/>
            <ToggleButton x:Name="IsTextlessToggleButton"
                          Background="{DynamicResource SurfaceContainerBrush}"
                          Foreground="{DynamicResource ContentMutedBrush}"
                          BorderBrush="{DynamicResource OutlineSubtleBrush}"
                          BorderThickness="2"
                          Padding="10"/>
            <TextBlock Text="Содержит ли шокирующий контент" Foreground="{DynamicResource ContentPrimaryBrush}" Margin="0 5"/>
            <ToggleButton x:Name="IsExplicitToggleButton"
                          Background="{DynamicResource SurfaceContainerBrush}"
                          Foreground="{DynamicResource ContentMutedBrush}"
                          BorderBrush="{DynamicResource OutlineSubtleBrush}"
                          BorderThickness="2"
                          Padding="10"/>
        </StackPanel>
        <Button x:Name="ConfirmButton" Grid.Row="2" Content="Подтвердить" Padding="0 10"
                Background="{DynamicResource SurfaceContainerBrush}"
                Foreground="{DynamicResource ContentMutedBrush}"
                BorderBrush="{DynamicResource OutlineSubtleBrush}"
                BorderThickness="2"
                Click="ConfirmButton_OnClick"/>
    </Grid>
    </Border>
</Window>
