<Window x:Class="Desktop_Amethyst_Audio.Views.ModalWindows.TrackFormModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.ModalWindows"
        mc:Ignorable="d" Loaded="TrackFormModalWindow_OnLoaded"
        Title="TrackFormModalWindow" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <TextBox x:Name="TrackNameTextBox" 
                 Grid.Column="0" Grid.Row="0"
                 VerticalAlignment="Center" 
                 Margin="10 0" Padding="5"/>
        <Button x:Name="TrackFileSelectorButton"
                Content="Выбрать"
                Grid.Column="0" Grid.Row="1"
                VerticalAlignment="Center" 
                Margin="10 0" Padding="5"
                Click="TrackFileSelectorButton_OnClick"/>
        <Button x:Name="TrackCoverSelectorButton"
                Content="Выбрать"
                Grid.Column="0" Grid.Row="2"
                VerticalAlignment="Center" 
                Margin="10 0" Padding="5"
                Click="TrackCoverSelectorButton_OnClick"/>
        <ListBox x:Name="GenreListBox" 
                 Grid.Column="0" Grid.Row="3" 
                 SelectionMode="Multiple"
                 Margin="10 0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" 
                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <ComboBox x:Name="TrackPaceComboBox"
                  Grid.Column="0" Grid.Row="4"
                  VerticalAlignment="Center" 
                  Margin="10 0" Padding="5"/>
        <ComboBox x:Name="TrackMoodComboBox"
                  Grid.Column="0" Grid.Row="5"
                  VerticalAlignment="Center" 
                  Margin="10 0" Padding="5"/>
        <ToggleButton x:Name="IsTrackTextlessToggleButton"
                      Content="Содержит ли текст"
                      Grid.Column="0" Grid.Row="6"
                      VerticalAlignment="Center" 
                      Margin="10 0" Padding="5"/>
        <ToggleButton x:Name="IsTrackExplicitToggleButton"
                      Content="Содержит ли шокирующий контент"
                      Grid.Column="0" Grid.Row="7"
                      VerticalAlignment="Center" 
                      Margin="10 0" Padding="5"/>
        <ComboBox x:Name="CountryComboBox"></ComboBox>
        <Button x:Name="ConfirmButton" 
                Content="Подтвердить"
                Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                Margin="10" Click="ConfirmButton_OnClick"/>
    </Grid>
</Window>
