<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.AlbumPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d" Loaded="AlbumPage_OnLoaded"
      Title="AlbumPage" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Margin="5" Grid.Row="0" Background="Brown" BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Image x:Name="AlbumCoverImage" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="5" Source="../../Assets/test.jpg" Width="150"/>
                <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="1">
                    <TextBlock x:Name="NameTextBlock" Text="This Text is a placeholder" FontSize="32" Margin="5 10"/>
                    <StackPanel x:Name="AuthorStackPanel" Orientation="Horizontal" Margin="5 0">
                        <TextBlock Text="Author1"/>
                        <TextBlock Text="Author2"/>
                        <TextBlock Text="Author3"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
                    <Button Content="Добавить" VerticalAlignment="Center" Padding="20 10"/>
                    <Button Content="Слушать" VerticalAlignment="Center" Padding="20 10"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <ListBox x:Name="TrackListBox" BorderThickness="0" Background="Transparent" Grid.Row="1" Margin="5"/>
    </Grid>
</Page>
