<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.ForgetPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d" d:Background="{DynamicResource SurfaceBaseBrush}"
      Title="ForgetPasswordPage" d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Button x:Name="BackToLoginButton" Style="{StaticResource ButtonPrimary}"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="10" Width="50" Height="50" Click="BackToLoginButton_OnClick">
            <Image Source="../../../Assets/arrow-left.png" Width="24" />
        </Button>
        <TextBlock Text="В разработке" FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</Page>
