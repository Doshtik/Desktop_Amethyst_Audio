<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      d:Background="{DynamicResource SurfaceContainerBrush}"
      Title="RegisterPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="BackToLoginButton" Style="{StaticResource ButtonPrimary}"
                HorizontalAlignment="Left" VerticalAlignment="Top" Click="NavigateToAuth"
                Margin="10" Width="50" Height="50" Grid.Row="0" Grid.Column="0">
            <Image Source="../../../Assets/arrow-left.png" Width="24" />
        </Button>
        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button x:Name="ChangeThemeButton" Style="{StaticResource ButtonPrimary}" 
                    Margin="0 10 5 0" Width="50" Height="50"
                    Click="ChangeThemeButton_OnClick">
                <Image Source="../../../Assets/sun_icon.png" Width="24" />
            </Button>
            <Button x:Name="ChangeLanguageButton" Style="{StaticResource ButtonPrimary}" 
                    Margin="5 10 10 0" Width="50" Height="50"
                    Click="ChangeLanguageButton_OnClick">
                <TextBlock Text="Ru" Margin="0 5 0 5" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource ContentPrimaryBrush}"/>
            </Button>
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Width="300">
            <Image Source="../../../Assets/icon_256x256.png" Width="100"/>
            <TextBlock Text="Регистрация" 
                       Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="24" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>
            <Border  Background="{DynamicResource SurfaceContainerBrush}" 
                     BorderThickness="1" BorderBrush="{DynamicResource OutlineSubtleBrush}" 
                     CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Никнейм" Foreground="{DynamicResource ContentPrimaryBrush}"
                               FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <TextBox x:Name="NicknameTextBox" Padding="5" FontSize="18" 
                                 Background="Transparent" BorderThickness="0"
                                 Text="{Binding NicknameField}"/>
                    </Border>
                    <TextBlock Text="Email" Foreground="{DynamicResource ContentPrimaryBrush}"
                               FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <TextBox x:Name="EmailTextBox" Padding="5" FontSize="18" 
                                 Background="Transparent" BorderThickness="0"
                                 Text="{Binding EmailField}"/>
                    </Border>
                    <TextBlock Text="Пароль" 
                               Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <PasswordBox x:Name="RegisterPasswordBox" Padding="5"
                                     FontSize="18" Background="Transparent" BorderThickness="0"/>
                    </Border>
                    <Border x:Name="ErrorFieldBorder" Background="{DynamicResource StatusErrorBrush}"
                            Visibility="Collapsed" CornerRadius="10" Padding="10">
                        <TextBlock x:Name="ErrorFieldTextBlock" Foreground="{DynamicResource ContentPrimaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
            <Button x:Name="RegisterButton" Style="{DynamicResource ButtonPrimary}"
                    Margin="0,15,0,5" Click="RegisterButton_OnClick">
                <TextBlock Text="Войти" Margin="0 5 10 5" VerticalAlignment="Center"
                           FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
            </Button>
        </StackPanel>
    </Grid>
</Page>
