<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Desktop_Amethyst_Audio.ViewModels.PageViewModels"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d"
      Title="AuthPage" FontFamily="Inter"
      d:Background="{DynamicResource SurfaceBaseBrush}" d:DesignWidth="800" d:DesignHeight="600"
      d:DataContext="{d:DesignInstance Type=vm:AuthPageViewModel}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button x:Name="AuthChangeThemeButton" Style="{StaticResource ButtonPrimary}" 
                    Margin="0 10 5 0" Width="50" Height="50" 
                    Command="{Binding ChangeThemeCommand}">
                    <Image Source="{Binding ThemeIconPath}" Width="24" />
            </Button>
            <Button x:Name="AuthChangeLanguageButton" Style="{StaticResource ButtonPrimary}" 
                    Margin="5 10 10 0" Width="50" Height="50"
                    Command="{Binding ChangeLanguageCommand}">
                    <TextBlock Text="{Binding LanguageButtonText}" Margin="0 5 0 5" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ContentPrimaryBrush}"/>
            </Button>
        </StackPanel>
        
        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Width="300">
            <TextBlock x:Name="AuthTitleTextBlock" Text="Аутентификация" 
                       Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="24" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>
        
            <Border Background="{DynamicResource SurfaceContainerBrush}" 
                    BorderThickness="1" BorderBrush="{DynamicResource OutlineSubtleBrush}" 
                    CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock x:Name="AuthEmailTextBlock" Text="Email" Foreground="{DynamicResource ContentPrimaryBrush}"
                               FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <TextBox x:Name="AuthEmailTextBox" Padding="5" Text="{Binding EmailField}"
                                FontSize="18" Background="Transparent" BorderThickness="0"/>
                    </Border>
                    
                
                    <TextBlock x:Name="AuthPasswordTextBlock" Text="Пароль" 
                               Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <PasswordBox x:Name="AuthPasswordBox" Padding="5" 
                                FontSize="18" Background="Transparent" BorderThickness="0"/>
                    </Border>
                
                    <TextBlock x:Name="AuthForgetPasswordTextBlock"
                        Text="Забыли пароль?" 
                        FontSize="14"
                        Foreground="{DynamicResource ContentPrimaryBrush}" 
                        HorizontalAlignment="Right"
                        TextDecorations="Underline" 
                        Cursor="Hand"/>
                    
                    <Border x:Name="ErrorBorder" Background="{DynamicResource StatusErrorBrush}" CornerRadius="10" 
                            Visibility="{Binding ErrorVisibility}" Padding="15" Margin="0 10 0 0">
                        <TextBlock x:Name="ErrorTextBlock" Text="{Binding ErrorField}"
                                   Foreground="{DynamicResource ContentPrimaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
            
            <Button x:Name="AuthEnterButton" Style="{DynamicResource ButtonPrimary}"
                    Margin="0,15,0,5" 
                    Command="{Binding EnterButtonOnClickCommand}"
                    CommandParameter="{Binding ElementName=AuthPasswordBox}">
                <TextBlock Text="Войти" Margin="0 5 10 5" VerticalAlignment="Center"
                           FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
            </Button>
            <StackPanel x:Name="AuthProvidersStackPanel" Orientation="Vertical">
                <Button x:Name="AuthExternalGoogleButton" Style="{DynamicResource ButtonPrimary}"
                        FontSize="18" FontFamily="Inter" Margin="0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="../../Assets/google_logo.png" Width="25" Margin="0 0 5 0"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="Google" Margin="0 5 10 5" VerticalAlignment="Center"
                                   FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AuthExternalYandexButton" Style="{DynamicResource ButtonPrimary}"
                        FontSize="18" FontFamily="Inter" Margin="0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="../../Assets/yandex_logo.png" Width="25" Margin="0 0 5 0"/>
                        <TextBlock Text="Яндекс" Margin="0 5 0 5" VerticalAlignment="Center"
                                   FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock x:Name="AuthHaveNoAccountTextBlock" HorizontalAlignment="Center"
                       Text="Ещё нет аккаунта?" FontSize="16"
                       Foreground="{DynamicResource ContentPrimaryBrush}" />
            <TextBlock x:Name="AuthNavigateToRegisterTextBlock" HorizontalAlignment="Center" FontSize="16">
                <Hyperlink Command="{Binding NavigateToRegisterCommand}" 
                           Foreground="{DynamicResource ContentPrimaryBrush}"
                           TextDecorations="Underline">
                    Зарегистрируйся
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
