<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Desktop_Amethyst_Audio.ViewModels.PageViewModels"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d"
      Title="AuthPage" FontFamily="Inter"
      d:Background="{DynamicResource SurfaceBaseBrush}" d:DesignWidth="800" d:DesignHeight="600"
      d:DataContext="{d:DesignInstance Type=vm:AuthPageViewModel}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button x:Name="ChangeThemeButton" Style="{StaticResource ButtonPrimary}" 
                    Margin="0 10 5 0" Width="50" Height="50">
                    <Image Source="../../Assets/test.jpg" Width="24" />
            </Button>
            <Button x:Name="ChangeLanguageButton" Style="{StaticResource ButtonPrimary}" 
                    Margin="5 10 10 0" Width="50" Height="50">
                    <TextBlock Text="Ru" Margin="0 5 0 5" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ContentPrimaryBrush}"/>
            </Button>
        </StackPanel>
        
        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Width="300">
            <TextBlock Text="Авторизация" 
                       Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="24" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>
        
            <Border Background="{DynamicResource SurfaceContainerBrush}" 
                    BorderThickness="2" BorderBrush="{DynamicResource OutlineSubtleBrush}" 
                    CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Никнейм или Email" Foreground="{DynamicResource ContentPrimaryBrush}"
                               FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <TextBox x:Name="EmailOrPasswordTextBox" Padding="5" 
                                FontSize="18" Background="Transparent" BorderThickness="0"/>
                    </Border>
                    
                
                    <TextBlock Text="Пароль" 
                               Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18"
                               Margin="5,0,0,5"/>
                    <Border Background="{DynamicResource ContentMutedBrush}" CornerRadius="10"
                            Margin="0,0,0,10">
                        <PasswordBox x:Name="PasswordBox" Padding="5"
                                FontSize="18" Background="Transparent" BorderThickness="0"/>
                    </Border>
                
                    <TextBlock x:Name="ForgetPasswordTextBlock"
                        Text="Забыли пароль?" 
                        FontSize="14"
                        Foreground="{DynamicResource ContentPrimaryBrush}" 
                        HorizontalAlignment="Right"
                        TextDecorations="Underline" 
                        Cursor="Hand"/>
                    
                    <Border Background="{DynamicResource StatusErrorBrush}" CornerRadius="10" Visibility="Collapsed" Padding="15" Margin="0 10 0 0">
                        <TextBlock Text="Ошибка: Пользователь не найден." Foreground="{DynamicResource ContentPrimaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
            
            <Button x:Name="EnterButton" Style="{DynamicResource ButtonPrimary}"
                    Margin="0,15,0,5">
                <TextBlock Text="Войти" Margin="0 5 10 5" VerticalAlignment="Center"
                           FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
            </Button>
            <StackPanel x:Name="AuthProvidersStackPanel" Orientation="Vertical">
                <Button x:Name="GoogleButton" Style="{DynamicResource ButtonPrimary}"
                        FontSize="18" FontFamily="Inter" Margin="0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="../../Assets/test.jpg" Width="24" Margin="0 0 5 0"/>
                        <TextBlock Text="Google" Margin="0 5 10 5" VerticalAlignment="Center"
                                   FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="YandexButton" Style="{DynamicResource ButtonPrimary}"
                        FontSize="18" FontFamily="Inter" Margin="0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="../../Assets/test.jpg" Width="24" Margin="0 0 5 0"/>
                        <TextBlock Text="Яндекс" Margin="0 5 0 5" VerticalAlignment="Center"
                                   FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock x:Name="HaveNoAccountTextBlock" HorizontalAlignment="Center"
                       Text="Ещё нет аккаунта?" FontSize="16"
                       Foreground="{DynamicResource ContentPrimaryBrush}" />
            <TextBlock HorizontalAlignment="Center" FontSize="16">
                <Hyperlink Command="{Binding NavigateToRegisterCommand}" 
                           Foreground="{DynamicResource ContentPrimaryBrush}"
                           TextDecorations="Underline">
                    Зарегистрируйся
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
