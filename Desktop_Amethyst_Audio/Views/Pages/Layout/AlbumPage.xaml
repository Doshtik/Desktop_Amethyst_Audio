<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.AlbumPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d" Loaded="AlbumPage_OnLoaded"
      KeepAlive="False"
      d:Background="{DynamicResource SurfaceBaseBrush}"
      Title="AlbumPage" d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Border Margin="5" Background="BlueViolet" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Image x:Name="AlbumImage" Source="/Assets/test.jpg" Margin="10" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"/>
                <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Grid.Column="1" Grid.Row="0">
                    <TextBlock Text="АЛЬБОМ" FontSize="10" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <TextBlock x:Name="AlbumNameTextBlock" Text="Название альбома" FontWeight="Medium"
                               Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18" />
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="Light" Text="Количество треков:" 
                                   Grid.Column="0"
                                   Foreground="{DynamicResource ContentPrimaryBrush}"/>
                        <TextBlock x:Name="TrackAmountTextBlock" FontWeight="Light" Text="10" 
                                   Grid.Column="1" Margin="5 0"
                                   Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0 10" Grid.Row="1" VerticalAlignment="Bottom">
                    <Button x:Name="PlayAlbumButton" Content="Слушать" Style="{StaticResource ButtonPrimary}"
                            Click="PlayAlbumButton_OnClick"/>
                    <Button x:Name="SaveAlbumButton" Content="Сохранить" Style="{StaticResource ButtonPrimary}" Margin="5 0"
                            Click="SaveAlbumButton_OnClick"/>
                    <ToggleButton x:Name="ActionsToggleButton" Background="Transparent" BorderThickness="0">
                        <ToggleButton.Content>
                            <Image Source="../../../Assets/dots_white.png" Height="25"/>
                        </ToggleButton.Content>
                    </ToggleButton>
                    <Popup>
                        <StackPanel x:Name="AlbumActionsStackPanel" Orientation="Vertical"/>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>
        <ListBox x:Name="TrackListBox" Grid.Row="1" Margin="5" Background="Transparent" BorderThickness="0"
                 SelectionChanged="TrackListBox_OnSelectionChanged"/>
    </Grid>
</Page>
