<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages" 
      d:Background="{DynamicResource SurfaceBaseBrush}" Loaded="ProfilePage_OnLoaded"
      KeepAlive="False"
      Title="ProfilePage" d:DesignHeight="600" d:DesignWidth="800"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="5">
            <Image x:Name="UserHeaderImage" Source="/Assets/default-header.jpg" Stretch="Fill"/>
            <ToggleButton x:Name="ProfileActionsToggleButton" Width="25" Margin="5"
                VerticalAlignment="Top" HorizontalAlignment="Right" 
                Background="Transparent" BorderThickness="0">
                <ToggleButton.Content>
                    <Image Source="../../../Assets/dots_white.png"/>
                </ToggleButton.Content>
            </ToggleButton>
            <Popup x:Name="ProfileActionsPopup"
                   IsOpen="{Binding IsChecked, ElementName=ProfileActionsToggleButton}"
                   PlacementTarget="{Binding ElementName=ProfileActionsToggleButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource SurfaceContainerBrush}" 
                        CornerRadius="5" BorderThickness="2" BorderBrush="{DynamicResource OutlineSubtleBrush}">
                    <StackPanel x:Name="PopupContentPanel" Orientation="Vertical"/>
                </Border>
            </Popup>
            <Grid VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="UserAvatarImage" Grid.Column="0" Source="/Assets/test.jpg" Margin="5"/>
                <Grid Grid.Column="1" Margin="0 5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid VerticalAlignment="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="UserNicknameTextBlock" Grid.Row="0" Text="Наименование пользователя" 
                                   VerticalAlignment="Bottom"  FontSize="18" FontWeight="Medium" 
                                    Foreground="{DynamicResource ContentPrimaryBrush}"/>
                        <StackPanel Grid.Row="1" VerticalAlignment="Top" Orientation="Horizontal">
                            <TextBlock Text="Количество подписчиков:" FontSize="14" 
                                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
                            <TextBlock x:Name="UserAmountOfSubsTextBlock" Text="123321" FontSize="14" Margin="5 0 0 0"
                                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="UserProfileActionsStackPanel" Orientation="Horizontal" 
                                    Grid.Row="2" Visibility="Visible" Margin="0 5 0 0">
                            <Button x:Name="FollowingUserButton" Content="Подписаться" Style="{StaticResource ButtonPrimary}" 
                                    Click="FollowingUserButton_Click"/>
                            <ToggleButton x:Name="NotificationToggleButton" 
                                          Padding="5" Margin="5 0 0 0"
                                          Background="{DynamicResource SurfaceContainerBrush}"
                                          BorderThickness="1" BorderBrush="{DynamicResource OutlineSubtleBrush}">
                                <ToggleButton.Content>
                                    <Image Source="../../../Assets/Bell.png" Width="15"/>
                                </ToggleButton.Content>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel x:Name="ActionStackPanel" Grid.Row="0" HorizontalAlignment="Left" 
                        Margin="5 0" Orientation="Horizontal">
                <Button x:Name="ReleaseTrackButton" Content="Выпустить трек" 
                        Style="{StaticResource ButtonPrimary}"
                        Margin="0 0 5 0" Click="ReleaseTrackButton_OnClick"/> 
                <Button x:Name="ReleaseAlbumButton" Content="Выпустить альбом"
                        Style="{StaticResource ButtonPrimary}"
                        Click="ReleaseAlbumButton_OnClick"/>
            </StackPanel>
            <Grid Grid.Row="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Список треков" Grid.Column="0" Foreground="{DynamicResource ContentPrimaryBrush}" 
                               FontSize="14"/>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Visibility="Collapsed">
                        <Hyperlink x:Name="NavigateToListOfTracks" Foreground="{DynamicResource ContentPrimaryBrush}">
                            Все
                        </Hyperlink>
                    </TextBlock>
                </Grid>
                <ListBox x:Name="UserTrackListBox" Grid.Row="1" Margin="0 5 0 0"
                     Background="Transparent" BorderThickness="0"
                     SelectionChanged="UserTrackListBox_OnSelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
            <Grid Grid.Row="2" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Список альбомов" Grid.Column="0" Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="14"/>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Visibility="Collapsed">
                        <Hyperlink x:Name="NavigateToListOfAlbums" Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="14">
                            Все
                        </Hyperlink>
                    </TextBlock>
                </Grid>
                <ListBox x:Name="UserAlbumListBox" Grid.Row="1" Margin="0 5 0 0" 
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="UserAlbumListBox_OnSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="2" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
            <Grid Grid.Row="3" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Список плейлистов" Grid.Column="0" Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="14"/>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Visibility="Collapsed">
                        <Hyperlink x:Name="NavigateToListOfPlaylists" Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="14">
                            Все
                        </Hyperlink>
                    </TextBlock>
                </Grid>
                <ListBox x:Name="UserPlaylistListBox" Grid.Row="1" Margin="0 5 0 0"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="UserPlaylistListBox_OnSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="2" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</Page>
