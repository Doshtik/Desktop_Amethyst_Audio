<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.SearchResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d" d:Background="{DynamicResource SurfaceBaseBrush}"
      KeepAlive="False" Background="{DynamicResource SurfaceBaseBrush}"
      Loaded="SearchResultPage_OnLoaded"
      Title="SearchResultPage" d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            
            <!-- 1. Пользователи -->
            <TextBlock Text="Пользователи" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,12" 
                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
            
            <ListBox x:Name="UserListBox"
                     BorderThickness="0" 
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     SelectionChanged="UserListBox_OnSelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <!-- 2. Треки -->
            <TextBlock Text="Треки" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       Margin="0,32,0,12" 
                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
            
            <ListBox x:Name="TrackListBox"
                     BorderThickness="0" 
                     Background="Transparent"
                     SelectionChanged="TrackListBox_OnSelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <!-- 3. Альбомы -->
            <TextBlock Text="Альбомы" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       Margin="0,32,0,12" 
                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
            
            <ListBox x:Name="AlbumListBox"
                     BorderThickness="0" 
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     SelectionChanged="AlbumListBox_OnSelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <!-- 4. Плейлисты -->
            <TextBlock Text="Плейлисты" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       Margin="0,32,0,12" 
                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
            
            <ListBox x:Name="PlaylistListBox"
                    BorderThickness="0" 
                    Background="Transparent"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    SelectionChanged="PlaylistListBox_OnSelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</Page>
