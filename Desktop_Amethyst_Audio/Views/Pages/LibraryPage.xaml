<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      xmlns:tracks="clr-namespace:Desktop_Amethyst_Audio.Models.DTO.Tracks"
      xmlns:userControls="clr-namespace:Desktop_Amethyst_Audio.Views.UserControls"
      mc:Ignorable="d" Loaded="LibraryPage_OnLoaded"
      Title="LibraryPage" d:Background="{DynamicResource SurfaceBaseBrush}" d:DesignHeight="600" d:DesignWidth="800"
      SizeChanged="LibraryPage_OnSizeChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Border Grid.Column="0" Margin="5" Background="BlueViolet" CornerRadius="10">
            <TextBlock Text="Библиотека" Foreground="{DynamicResource ContentPrimaryBrush}" 
                       VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5" FontSize="48"
                       FontWeight="Bold"/>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="5 0">
            <Border Height="2" Margin="0 3" CornerRadius="2" Background="{DynamicResource ContentPrimaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Количество треков:" FontSize="14" Margin=" 0 0 5 0"
                               VerticalAlignment="Center" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <TextBlock x:Name="AmountOfTrackTextBlock" Text="150" FontSize="14" 
                               VerticalAlignment="Center" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                </StackPanel>
                <ComboBox x:Name="SortComboBox" Grid.Column="2" HorizontalAlignment="Right" SelectedIndex="0" 
                          FontSize="14" Foreground="{DynamicResource ContentPrimaryBrush}"
                          Background="Transparent" BorderThickness="0"
                          SelectionChanged="SortComboBox_OnSelectionChanged">
                    <ComboBoxItem Content="По-умолчанию"/>
                    <ComboBoxItem Content="По дате добавления"/>
                    <ComboBoxItem Content="По названию"/>
                    <ComboBoxItem Content="По исполнителю"/>
                    <ComboBoxItem Content="По году"/>
                </ComboBox>
            </Grid>
        </StackPanel>
        <ListBox x:Name="TrackListBox" ItemsSource="{Binding Controls}" Grid.Row="2" Margin="5 0" Background="Transparent" BorderThickness="0"
                 SelectionChanged="TrackListBox_OnSelectionChanged"/>
    </Grid>
</Page>
