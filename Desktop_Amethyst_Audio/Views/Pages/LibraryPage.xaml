<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      xmlns:vm="clr-namespace:Desktop_Amethyst_Audio.ViewModels.PageViewModels"
      mc:Ignorable="d"
      Title="LibraryPage" d:DesignHeight="600" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=vm:LibraryPageViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Border Grid.Column="0" Margin="5" Background="BlueViolet" CornerRadius="10">
            <TextBlock Text="Библиотека" Foreground="{DynamicResource ContentPrimaryBrush}" 
                       VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5" FontSize="48"
                       FontWeight="Bold"/>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="5 0">
            <Border Height="2" Margin="0 3" CornerRadius="2" Background="{DynamicResource ContentPrimaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Количество треков:" FontSize="14" Margin=" 0 0 5 0"
                               VerticalAlignment="Center" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <TextBlock x:Name="AmountOfTrackTextBlock" Text="150" FontSize="14" 
                               VerticalAlignment="Center" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock x:Name="SortTypeTextBlock" Text="По-умолчанию" FontSize="14"
                               VerticalAlignment="Center" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <TextBlock Text=":" FontSize="14" VerticalAlignment="Center" 
                               Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <Button Margin="5 0 0 0" Background="Transparent" BorderThickness="0">
                        <Button.Content>
                            <Image Source="../../Assets/angle-small-down.png" Width="25"/>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="По-умолчанию"/>
                                <MenuItem Header="По дате добавления"/>
                                <MenuItem Header="По названию"/>
                                <MenuItem Header="По исполнителю"/>
                                <MenuItem Header="По году"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>
        <ListBox x:Name="TrackListBox" ItemsSource="{Binding Controls}" Grid.Row="2" Margin="5 0" Background="Transparent" BorderThickness="0" SelectionChanged="TrackListBox_OnSelectionChanged"/>
    </Grid>
</Page>
