<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.PlaylistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      mc:Ignorable="d" d:Background="{DynamicResource SurfaceBaseBrush}"
      Loaded="Page_Loaded"
      Title="PlaylistPage" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Border Margin="5" Background="BlueViolet" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Image x:Name="PlaylistImage" Source="/Assets/test.jpg" Margin="10" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"/>
                <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Grid.Column="1" Grid.Row="0">
                    <TextBlock Text="ПЛЕЙЛИСТ" FontSize="10" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <TextBlock x:Name="PlaylistName" Text="Название плейлиста" FontWeight="Medium"
                               Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0 0 5 0">
                            <Hyperlink x:Name="AuthorNameHyperLink"
                                       Click="AuthorNameHyperLink_Click" FontWeight="Light"
                                       Foreground="{DynamicResource ContentPrimaryBrush}">
                                Имя пользователя
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock x:Name="TrackAmounttextBlock" FontWeight="Light" Text="Количество треков: 150" 
                                   Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0 10" VerticalAlignment="Bottom" Grid.Row="1">
                    <Button x:Name="PlayPlaylistButton" Content="Слушать" Style="{StaticResource ButtonPrimary}"/>
                    <Button x:Name="NavigateToPrevious" Content="Назад" Style="{StaticResource ButtonPrimary}" Margin="5 0"/>
                    <ComboBox x:Name="PlaylistActionsComboBox" Background="Transparent" BorderThickness="0">
                        <ComboBoxItem x:Name="AddToSaved" Content="Сохранить плейлист" Selected="AddToSaved_Selected"/>
                        <ComboBoxItem x:Name="EditPlaylist" Content="Настройки плейлиста" Visibility="Collapsed" Selected="EditPlaylist_Selected"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Margin="5" Orientation="Vertical">
            <ListBox x:Name="TrackListBox" Background="Transparent" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>
