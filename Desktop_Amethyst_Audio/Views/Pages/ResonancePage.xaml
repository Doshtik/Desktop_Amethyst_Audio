<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.ResonancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      xmlns:waveVizualizer="clr-namespace:Desktop_Amethyst_Audio.Views.CustomElements.WaveVisualizer"
      mc:Ignorable="d" d:Background="{DynamicResource SurfaceBaseBrush}"
      Background="{DynamicResource SurfaceBaseBrush}"
      Title="ResonancePage" d:DesignHeight="600" d:DesignWidth="800">
    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
        <waveVizualizer:WaveRenderer x:Name="Sphere"/>
        <Button x:Name="ResonanceSettingsButton" Content="Настройки" FontSize="18" 
                Style="{DynamicResource ButtonPrimary}" Margin="0 10 0 0" Click="ResonanceSettingsButton_OnClick"/>
    </StackPanel>
</Page>
