<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.ResonancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
      xmlns:waveVizualizer="clr-namespace:Desktop_Amethyst_Audio.Views.CustomElements.WaveVisualizer"
      mc:Ignorable="d" d:Background="{DynamicResource SurfaceBaseBrush}"
      Background="{DynamicResource SurfaceBaseBrush}"
      Title="ResonancePage" d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <waveVizualizer:WaveRenderer x:Name="Sphere"/>
        
        <Button x:Name="ResonanceSettingsButton"
                VerticalAlignment="Top"
                HorizontalAlignment="Right" Width="50" Height="50"
                Style="{DynamicResource ButtonPrimary}" Margin="5" Click="ResonanceSettingsButton_OnClick">
            <Button.Content>
                <Image Source="../../Assets/gear.png" Width="25"/>
            </Button.Content>
        </Button>
        
        <Border Background="{DynamicResource SurfaceContainerBrush}" 
                CornerRadius="10"
                BorderThickness="2" BorderBrush="{DynamicResource OutlineSubtleBrush}"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Margin="10">
                <TextBlock Text="Настроить резонанс" 
                           Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18"/>
                <Button x:Name="ResonanceConfigButton" Content="Настроить" Margin="0 10 0 0" FontSize="14" 
                        Click="ResonanceConfigButton_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
