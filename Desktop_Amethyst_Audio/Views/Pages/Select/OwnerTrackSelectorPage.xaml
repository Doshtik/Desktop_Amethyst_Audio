<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.Select.OwnerTrackSelectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages.Select"
      mc:Ignorable="d" Background="#00000080" Loaded="OwnerTrackSelectorPage_OnLoaded"
      Title="OwnerTrackSelectorPage" d:DesignHeight="400" d:DesignWidth="600">
    <Grid>
        <Button x:Name="BackButton" VerticalAlignment="Top" HorizontalAlignment="Left" 
                Margin="10" Padding="5"
                Click="BackButton_OnClick"
                Background="{DynamicResource SurfaceContainerBrush}"
                BorderBrush="{DynamicResource OutlineSubtleBrush}"
                BorderThickness="2">
            <Button.Content>
                <Image x:Name="BackImage" Source="../../../Assets/arrow-left.png" Width="20"/>
            </Button.Content>
        </Button>
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" 
              Width="300" Height="300">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ListBox x:Name="TrackListBox" Grid.Row="0" 
                     SelectionMode="Multiple"
                     Background="Transparent"
                     BorderBrush="{DynamicResource OutlineSubtleBrush}"/>
            <Button x:Name="ConfirmButton" Grid.Row="1"
                    Content="Подтвердить" FontSize="14"
                    Padding="5" Margin="0 10 0 0"
                    Click="ConfirmButton_OnClick"
                    Foreground="{DynamicResource ContentPrimaryBrush}"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineSubtleBrush}"
                    BorderThickness="2" />
        </Grid>
    </Grid>
</Page>
