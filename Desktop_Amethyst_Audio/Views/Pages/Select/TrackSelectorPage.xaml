<Page x:Class="Desktop_Amethyst_Audio.Views.Pages.Select.TrackSelectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Pages.Select"
      mc:Ignorable="d" Background="#00000080" Loaded="TrackSelectorPage_OnLoaded"
      FontSize="14"
      Title="TrackSelectorPage" d:DesignHeight="400" d:DesignWidth="600">
    <Grid>
        <Button x:Name="BackButton" VerticalAlignment="Top" HorizontalAlignment="Left" 
                Margin="10" Padding="5"
                Click="BackButton_OnClick"
                Background="{DynamicResource SurfaceContainerBrush}"
                BorderBrush="{DynamicResource OutlineSubtleBrush}"
                BorderThickness="2">
            <Button.Content>
                <Image x:Name="BackImage" Source="../../../Assets/arrow-left.png" Width="20"/>
            </Button.Content>
        </Button>
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" 
              Width="300" Height="300">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TrackNameTextBox" Grid.Column="0" Margin="0 0 5 0"
                         Foreground="{DynamicResource ContentPrimaryBrush}"
                         Background="{DynamicResource SurfaceContainerBrush}"
                         BorderBrush="{DynamicResource OutlineSubtleBrush}"
                         BorderThickness="2"/>
                <Button x:Name="SearchButton" Grid.Column="1" Padding="5"
                        Click="SearchButton_OnClick"
                        Background="{DynamicResource SurfaceContainerBrush}"
                        BorderBrush="{DynamicResource OutlineSubtleBrush}"
                        BorderThickness="2">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="../../../Assets/search.png" Width="15"/>
                            <TextBlock Text="Поиск" VerticalAlignment="Center" Margin="5 0 0 0"
                                       Foreground="{DynamicResource ContentPrimaryBrush}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
            <ListBox x:Name="TrackListBox" Grid.Row="1" Margin="0 5"
                     SelectionMode="Multiple"
                     Background="Transparent"
                     BorderBrush="{DynamicResource OutlineSubtleBrush}"/>
            <Button x:Name="ConfirmButton" Grid.Row="2"
                    Content="Подтвердить" FontSize="14"
                    Padding="5"
                    Click="ConfirmButton_OnClick"
                    Foreground="{DynamicResource ContentPrimaryBrush}"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineSubtleBrush}"
                    BorderThickness="2" />
        </Grid>
    </Grid>
</Page>
