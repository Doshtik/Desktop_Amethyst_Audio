<UserControl x:Class="Desktop_Amethyst_Audio.Views.UserControls.AlbumControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.UserControls"
             Loaded="AlbumControl_OnLoaded"
             mc:Ignorable="d" Width="130" Height="160">
    <Border Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
            <Image x:Name="AlbumCoverImage" Grid.Row="0" Margin="10" Source="/Assets/test.jpg"/>
            <TextBlock x:Name="AlbumNameTextBlock" Grid.Row="1" Text="Название альбома"
                       Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="14" Margin="10 0 10 10"/>
        </Grid>
    </Border>
</UserControl>
