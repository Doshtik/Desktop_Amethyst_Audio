<UserControl x:Class="Desktop_Amethyst_Audio.Views.UserControls.PlaylistControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="300">
    <Border Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="../../Assets/test.jpg" Margin="10"/>
            <TextBlock Grid.Column="1" x:Name="PlaylistNameTextBlock" Text="Название плейлиста" Foreground="{DynamicResource ContentPrimaryBrush}"
                       FontSize="18" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
