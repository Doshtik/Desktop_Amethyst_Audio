<UserControl x:Class="Desktop_Amethyst_Audio.Views.UserControls.QueueTrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.UserControls"
             mc:Ignorable="d" Loaded="TrackInQueueControl_OnLoaded" MouseLeftButtonUp="QueueTrackControl_OnMouseLeftButtonUp"
             Height="75" d:DesignWidth="500">
    <Border BorderThickness="2" BorderBrush="{DynamicResource OutlineSubtleBrush}" CornerRadius="10" Background="{DynamicResource SurfaceContainerBrush}">
        <Grid>
             <Grid.ColumnDefinitions>
                 <ColumnDefinition Width="Auto"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="Auto"/>
             </Grid.ColumnDefinitions>
            <Image x:Name="TrackImage" Grid.Column="0" Source="../../Assets/test.jpg" Margin="10"/>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="TrackNameTextBlock" Text="Название трека" 
                           Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18"
                           VerticalAlignment="Bottom" Grid.Row="0"/>
                <StackPanel x:Name="TrackUsersPanel" Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Top"/>
            </Grid>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10">
                <TextBlock x:Name="DurationTextBlock" Text="00:00" VerticalAlignment="Center" Margin="0 0 10 0" FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                <ToggleButton x:Name="ActionButton">
                    <ToggleButton.Content>
                        <Image Source="/Assets/test.jpg" Width="25"/>
                    </ToggleButton.Content>
                </ToggleButton>
                <Popup IsOpen="{Binding IsChecked, ElementName=ActionButton}" 
                       PlacementTarget="{Binding ElementName=ActionButton}"
                       Placement="Top" 
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="AddTrackInQueue" Content="Удалить из очереди"/>
                        <Button x:Name="AddTrackInLibrary" Content="Добавить в библиотеку" Visibility="Collapsed"/>
                        <Button x:Name="RemoveTrackFromLibrary" Content="Добавить в библиотеку" Visibility="Collapsed"/>
                        <Button x:Name="AddTrackInPlaylist" Content="Добавить в плейлист" Visibility="Collapsed"/>
                        <Button x:Name="RemoveTrackFromPlaylist" Content="Добавить в плейлист" Visibility="Collapsed"/>
                    </StackPanel>
                </Popup>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
