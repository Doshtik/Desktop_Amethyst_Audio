<UserControl x:Class="Desktop_Amethyst_Audio.Views.UserControls.TrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.UserControls"
             mc:Ignorable="d" Background="Transparent" Loaded="TrackControl_OnLoaded"
             d:DesignHeight="75" d:DesignWidth="500"
             Height="75">
    <Border BorderThickness="2" BorderBrush="{DynamicResource OutlineSubtleBrush}" CornerRadius="10" Background="{DynamicResource SurfaceContainerBrush}">
        <Grid>
             <Grid.ColumnDefinitions>
                 <ColumnDefinition Width="Auto"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="Auto"/>
             </Grid.ColumnDefinitions>
            <Image x:Name="TrackImage" Grid.Column="0" Source="../../Assets/test.jpg" Margin="10"/>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="TrackNameTextBlock" Text="Название трека" 
                           Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="18"
                           VerticalAlignment="Bottom" Grid.Row="0"/>
                <StackPanel x:Name="TrackUsersPanel" Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Top"/>
            </Grid>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10">
                <TextBlock x:Name="DurationTextBlock" Text="00:00" VerticalAlignment="Center" FontSize="18" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                <ComboBox Name="trackActions" Background="Transparent" BorderThickness="0" 
                          Margin="10 0 0 0" Foreground="{DynamicResource ContentPrimaryBrush}">
                    <ComboBoxItem x:Name="AddTrackInQueue" Content="Добавить в очередь" Selected="AddTrackInQueue_Selected"/>
                    <ComboBoxItem x:Name="AddTrackInLibrary" Content="Добавить в библиотеку" Selected="AddTrackInLibrary_Selected" Visibility="Collapsed"/>
                    <ComboBoxItem x:Name="AddTrackInPlaylist" Content="Добавить в плейлист" Selected="AddTrackInPlaylist_Selected"/>
                </ComboBox>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
