<Window x:Class="Desktop_Amethyst_Audio.Views.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:Desktop_Amethyst_Audio.ViewModels"
        xmlns:vm-pages="clr-namespace:Desktop_Amethyst_Audio.ViewModels.PageViewModels"
        xmlns:local="clr-namespace:Desktop_Amethyst_Audio.Views.Windows"
        xmlns:views="clr-namespace:Desktop_Amethyst_Audio.Views.Pages"
        mc:Ignorable="d" Background="{DynamicResource SurfaceBaseBrush}"
        Title="Авторизация" Icon="../../Assets/icon_128x128.ico"
        Height="720" Width="1280" WindowState="Maximized"
        MinHeight="600" MinWidth="800">
    <Window.Resources>
        <vm:AuthViewModel x:Key="AuthViewModel"/>
        <DataTemplate DataType="{x:Type vm-pages:AuthPageViewModel}">
            <views:AuthPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm-pages:RegisterPageViewModel}">
            <views:RegisterPage/>
        </DataTemplate>
    </Window.Resources>
    <Window.DataContext>
        <StaticResource ResourceKey="AuthViewModel" />
    </Window.DataContext>
    
    <Frame x:Name="MainFrame" Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden"/>
</Window>
