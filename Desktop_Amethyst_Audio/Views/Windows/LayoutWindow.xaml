<Window x:Class="Desktop_Amethyst_Audio.Views.Windows.LayoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:Desktop_Amethyst_Audio.Views.UserControls"
        mc:Ignorable="d" Title="Amethyst Audio" Icon="../../Assets/icon_128x128.ico"
        Background="{DynamicResource SurfaceBaseBrush}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Height="1080" Width="1920"
        MinHeight="600" MinWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="12*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel x:Name="SideBar" Orientation="Vertical"
                    Grid.Row="0" Grid.Column="0">
            <Grid Margin="10 10 10 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
    
                <Image Grid.Column="0" x:Name="AvatarImage" Width="75" Height="75"/>
    
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="UserNicknameTextBlock" Grid.Row="0" Text="Никнейм пользователя" Foreground="White"/>
                    <Button Grid.Row="1" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Выпадашка" Foreground="{DynamicResource ContentPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                                <Image Source="../../Assets/angle-small-down.png" Width="25"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Уведомления"/>
                                <MenuItem Header="Настройки"/>
                                <MenuItem Header="Выйти"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Grid>
            
            <Button x:Name="SearchButton" Content="Поиск" Style="{DynamicResource ButtonPrimary}"
                FontSize="22" FontFamily="Inter" Margin="0 10 0 5" 
                Click="NavigateToSearch"/>
            
            <Button x:Name="ResonanceButton" Content="Резонанс" Style="{DynamicResource ButtonPrimary}"
                    FontSize="22" FontFamily="Inter" Margin=" 0 5 0 5"
                    Click="NavigateToResonance"/>
            
            <Button x:Name="LibraryButton" Content="Библиотека" Style="{DynamicResource ButtonPrimary}"
                    FontSize="22" FontFamily="Inter" Margin="0 5 0 0"
                    Click="NavigateToLibrary"/>
            
            <ComboBox x:Name="UserSavedColectionsComboBox" Margin="0 10">
                <ComboBoxItem Content="Playlists"/>
                <ComboBoxItem Content="Playlists"/>
            </ComboBox>
            <ListBox x:Name="SavedPlaylistsListBox"/>
            <ListBox x:Name="SavedAlbumsListBox" Visibility="Collapsed">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
        
        <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"
               Grid.Row="0" Grid.Column="1"/>
        
        <Grid x:Name="TrackPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                    Background="{DynamicResource SurfaceContainerBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Grid x:Name="TrackInfoGrid" Grid.Column="0" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
    
                <Image Grid.Column="0" x:Name="TrackImage" Source="../../Assets/test.jpg" Width="75"/>
    
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Название трека" FontSize="16" 
                               Foreground="{StaticResource ContentPrimaryBrush}"/>
                    <TextBlock Grid.Row="1" Text="Имя исполнителей" FontSize="14" 
                               Foreground="{StaticResource ContentPrimaryBrush}"/>
                </Grid>
            </Grid>
            <Grid x:Name="TrackNavigationGrid" Grid.Column="1">
                 <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto"/>
                     <ColumnDefinition Width="*"/>
                 </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RepeatButton" Grid.Column="0" Background="Transparent" Padding="10" 
                            BorderThickness="0" VerticalAlignment="Center">
                        <Button.Content>
                            <Image Source="../../Assets/repeat.png" Width="25"/>
                        </Button.Content>
                    </Button>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BackButton" Grid.Column="0" Background="Transparent" Padding="10"  
                                BorderThickness="0" VerticalAlignment="Center">
                            <Button.Content>
                                <Image Source="../../Assets/back.png" Width="25"/>
                            </Button.Content>
                        </Button>
                        <Button x:Name="PlayPauseButton" Grid.Column="1" Background="{DynamicResource OutlineSubtleBrush}" Padding="10"  
                                BorderThickness="0" VerticalAlignment="Center">
                            <Button.Content>
                                <Image Source="../../Assets/test.jpg" Width="25"/>
                            </Button.Content>
                        </Button>
                        <Button x:Name="NextButton" Grid.Column="2" Background="Transparent" Padding="10"  
                                BorderThickness="0" VerticalAlignment="Center">
                            <Button.Content>
                                <Image Source="../../Assets/next.png" Width="25"/>
                            </Button.Content>
                        </Button>
                    </Grid>
                    <Button x:Name="ShuffleButton" Grid.Column="2" Background="Transparent" Padding="10"  
                            BorderThickness="0" VerticalAlignment="Center">
                        <Button.Content>
                            <Image Source="../../Assets/shuffle.png" Width="25"/>
                        </Button.Content>
                    </Button>
                </Grid>
                <Grid Grid.Column="1" Margin="10 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="CurrentTrackTimeTextBlock" Text="00:00"
                               VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                    <Slider Grid.Column="1" Margin="10 0" VerticalAlignment="Center"
                            Minimum="0"
                            Maximum="100" 
                            Value="0"
                            TickFrequency="1"
                            IsMoveToPointEnabled="True"/>
                    <TextBlock Grid.Column="2" x:Name="TotalTrackTimeTextBlock" Text="04:24"
                               VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource ContentPrimaryBrush}"/>
                </Grid>
            </Grid>
            <StackPanel x:Name="TrackActions" Grid.Column="1">
                
            </StackPanel>
        </Grid>
    </Grid>
</Window>
